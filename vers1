        right_panel.pack(side="right", fill="both", expand=True)
        
        # Piano Roll
        piano_frame = ttk.LabelFrame(right_panel, text="🎹 Piano Roll", padding=5)
        piano_frame.pack(fill="both", expand=True, pady=(0, 5))
        
        canvas_frame = ttk.Frame(piano_frame)
        canvas_frame.pack(fill="both", expand=True)
        
        self.piano_roll = PianoRoll(canvas_frame, height=300)
        self.piano_roll.pack(side="left", fill="both", expand=True)
        
        scrollbar_y = ttk.Scrollbar(canvas_frame, orient="vertical", command=self.piano_roll.yview)
        scrollbar_y.pack(side="right", fill="y")
        
        scrollbar_x = ttk.Scrollbar(piano_frame, orient="horizontal", command=self.piano_roll.xview)
        scrollbar_x.pack(side="bottom", fill="x")
        
        self.piano_roll.configure(yscrollcommand=scrollbar_y.set, xscrollcommand=scrollbar_x.set)
        
        # Лог
        log_frame = ttk.LabelFrame(right_panel, text="📋 Лог", padding=5)
        log_frame.pack(fill="both", expand=True)
        
        self.log_text = tk.Text(
            log_frame, height=6, wrap="word",
            bg='#f5f5f5', fg='#333333', insertbackground='#333333',
            relief='flat', borderwidth=1, font=('Consolas', 9)
        )
        scrollbar = ttk.Scrollbar(log_frame, command=self.log_text.yview)
        self.log_text.configure(yscrollcommand=scrollbar.set)
        self.log_text.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
        
        # Кнопка очистки
        ttk.Button(right_panel, text="🗑️ Очистить лог", command=self.clear_log).pack(pady=5)
        
        # Статус бар
        self.status_var = tk.StringVar(value="Готов к работе")
        status_bar = ttk.Label(self.root, textvariable=self.status_var, relief="sunken", anchor="w")
        status_bar.pack(fill="x", padx=10, pady=5)
        
        # Горячие клавиши
        self.root.bind('<Control-o>', lambda e: self.browse_file())
        self.root.bind('<Control-s>', lambda e: self.save_result() if self.save_button['state'] == 'normal' else None)
        self.root.bind('<Control-m>', lambda e: self.export_midi() if self.export_midi_button['state'] == 'normal' else None)
        self.root.bind('<space>', lambda e: self.player.play() if not self.player.is_playing else self.player.pause())
    
    def update_status(self, text):
        self.status_var.set(text)
    
    def browse_file(self):
        filetypes = [("Все поддерживаемые", "*.wav *.mp3"), ("WAV", "*.wav"), ("MP3", "*.mp3")]
        filename = filedialog.askopenfilename(title="Выберите аудиофайл", filetypes=filetypes)
        if filename:
            self.input_file_path.set(filename)
            self.log(f"📁 {os.path.basename(filename)}")
    
    def log(self, message):
        self.log_queue.put(message)
    
    def clear_log(self):
        self.log_text.config(state="normal")
        self.log_text.delete(1.0, tk.END)
        self.log_text.config(state="disabled")
    
    def process_log_queue(self):
        try:
            while True:
                msg = self.log_queue.get_nowait()
                self.log_text.config(state="normal")
                self.log_text.insert("end", msg + "\n")
                self.log_text.see("end")
                self.log_text.config(state="disabled")
        except queue.Empty:
            pass
        self.root.after(100, self.process_log_queue)
    
    def start_processing(self):
        if self.processing:
            return
        
        if not BASIC_PITCH_AVAILABLE:
            messagebox.showerror("Ошибка", "Basic Pitch не установлен!")
            return
        
        input_path = self.input_file_path.get().strip()
        if not input_path or not os.path.exists(input_path):
            messagebox.showerror("Ошибка", "Выберите существующий файл")
            return
        
        self.processing = True
        self.start_button.config(state="disabled")
        self.save_button.config(state="disabled")
        self.export_midi_button.config(state="disabled")
        self.progress.start(10)
        self.status_var.set("Обработка...")
        self.log("=" * 50)
        self.log(f"🚀 Обработка: {os.path.basename(input_path)}")
        
        thread = threading.Thread(target=self.process_file, args=(input_path,), daemon=True)
        thread.start()
    
    def process_file(self, input_path):
        try:
            ext = os.path.splitext(input_path)[1].lower()
            
            if ext == '.mp3':
                if self.mp3_converter is None:
                    raise ImportError("Установите librosa: pip install librosa")
                wav_path = self.convert_mp3_to_wav(input_path)
            else:
                wav_path = input_path
                self.log("   Формат WAV")
            
            self.log("🎵 Basic Pitch анализ...")
            
            model_output, midi_data, note_events = predict(
                wav_path,
                ICASSP_2022_MODEL_PATH,
                onset_threshold=self.onset_threshold.get(),
                frame_threshold=self.frame_threshold.get(),
                minimum_note_length=self.min_note_length.get(),
                minimum_frequency=80,
                maximum_frequency=2000
            )
            
            self.midi_data = midi_data
            note_count = sum(len(instr.notes) for instr in midi_data.instruments)
            self.log(f"✅ Распознано нот: {note_count}")
            
            if note_count == 0:
                self.log("⚠️ Ноты не найдены!")
            
            self.root.after(0, lambda: self.piano_roll.set_midi_data(midi_data))
            
            self.log("🎹 Синтез фортепиано...")
            self.synthesize_piano(midi_data)
            
            self.log(f"✅ Синтез завершён")
            self.log("=" * 50)
            
            self.root.after(0, self.processing_finished, True)
            
        except Exception as e:
            self.log(f"❌ ОШИБКА: {str(e)}")
            self.log(traceback.format_exc())
            self.log("=" * 50)
            self.root.after(0, self.processing_finished, False)
    
    def synthesize_piano(self, midi_data):
        sample_rate = 44100
        total_duration = midi_data.get_end_time() + 0.5
        num_samples = int(sample_rate * total_duration)
        audio = np.zeros(num_samples, dtype=np.float32)
        
        attack, decay, sustain, release = 0.005, 0.1, 0.7, 0.2
        note_count = 0
        
        for instrument in midi_data.instruments:
            if instrument.is_drum:
                continue
            for note in instrument.notes:
                note_count += 1
                freq = pretty_midi.note_number_to_hz(note.pitch)
                start_idx = int(note.start * sample_rate)
                duration = note.end - note.start
                note_len = int(duration * sample_rate)
                
                if note_len < 10:
                    continue
                
                envelope = np.ones(note_len)
                attack_len = int(attack * sample_rate)
                if attack_len > 0 and attack_len <= note_len:
                    envelope[:attack_len] = np.linspace(0, 1, attack_len)
                
                decay_len = int(decay * sample_rate)
                decay_start = attack_len
                decay_end = min(decay_start + decay_len, note_len)
                if decay_end > decay_start:
                    envelope[decay_start:decay_end] = np.linspace(1, sustain, decay_end - decay_start)
                
                sustain_start = decay_end
                if sustain_start < note_len:
                    envelope[sustain_start:] = sustain
                
                release_len = int(release * sample_rate)
                release_start = max(0, note_len - release_len)
                if release_start < note_len:
                    release_env = np.linspace(sustain, 0, note_len - release_start)
                    envelope[release_start:] = release_env
                
                t = np.linspace(0, duration, note_len, endpoint=False)
                signal = (0.7 * np.sin(2 * np.pi * freq * t) +
                          0.2 * np.sin(2 * np.pi * freq * 2 * t) +
                          0.1 * np.sin(2 * np.pi * freq * 3 * t))
                
                signal = signal * envelope * (note.velocity / 127.0)
                end_idx = min(start_idx + note_len, num_samples)
                audio[start_idx:end_idx] += signal[:end_idx - start_idx]
        
        max_val = np.max(np.abs(audio))
        if max_val > 0.9:
            audio = audio / max_val * 0.9
        
        fade_len = int(0.01 * sample_rate)
        if fade_len < num_samples:
            fade_env = np.linspace(1, 0, fade_len)
            audio[-fade_len:] *= fade_env
        
        self.temp_result_path = os.path.join(self.temp_dir, "result.wav")
        sf.write(self.temp_result_path, audio, sample_rate)
        
        self.result_audio_data = audio
        self.result_sample_rate = sample_rate
        
        self.log(f"   Синтезировано: {note_count} нот")
    
    def save_result(self):
        if self.result_audio_data is None:
            messagebox.showinfo("Информация", "Сначала обработайте аудиофайл")
            return
        
        file_path = filedialog.asksaveasfilename(
            defaultextension=".wav",
            filetypes=[("WAV файлы", "*.wav")],
            initialfile="piano_result.wav"
        )
        
        if file_path:
            try:
                sf.write(file_path, self.result_audio_data, self.result_sample_rate)
                self.log(f"💾 Сохранено: {os.path.basename(file_path)}")
                messagebox.showinfo("Успех", f"Файл сохранён!")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось сохранить:\n{e}")
    
    def export_midi(self):
        if self.midi_data is None:
            messagebox.showinfo("Информация", "Сначала обработайте аудиофайл")
            return
        
        file_path = filedialog.asksaveasfilename(
            defaultextension=".mid",
            filetypes=[("MIDI файлы", "*.mid")],
            initialfile="transcription.mid"
        )
        
        if file_path:
            try:
                self.midi_data.write(file_path)
                self.log(f"🎼 MIDI сохранён: {os.path.basename(file_path)}")
                messagebox.showinfo("Успех", "MIDI файл сохранён!")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось сохранить:\n{e}")
    
    def processing_finished(self, success):
        self.processing = False
        self.progress.stop()
        self.start_button.config(state="normal")
        
        if success:
            self.status_var.set("Готово!")
            self.save_button.config(state="normal")
            self.export_midi_button.config(state="normal")
            if hasattr(self, 'temp_result_path') and os.path.exists(self.temp_result_path):
                self.player.load_file(self.temp_result_path)
        else:
            self.status_var.set("Ошибка обработки")


def main():
    root = tk.Tk()
    app = SimplePianoTranscriber(root)
    app.process_log_queue()
    root.mainloop()

if __name__ == "__main__":
    main()
