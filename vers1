class PianoRoll(tk.Canvas):
    """Визуализация нот в виде Piano Roll (классическая тема)"""
    
    def __init__(self, parent, **kwargs):
        # Классическая тема
        kwargs['bg'] = '#2b2b2b'
        kwargs['highlightthickness'] = 0
        super().__init__(parent, **kwargs)
        
        self.notes = []
        self.note_rects = []
        self.min_pitch = 40  # E2
        self.max_pitch = 90  # F#6
        self.pixels_per_second = 100
        self.pixels_per_note = 14
        self.total_duration = 0
        self.scroll_x = 0
        self.scroll_y = 0
        self.grid_lines = []
        
        self.bind('<MouseWheel>', self.on_mousewheel)
        self.bind('<Button-4>', self.on_mousewheel)
        self.bind('<Button-5>', self.on_mousewheel)
        
        self.draw_piano_keys()
        self.draw_grid()
        
        # Привязываем обновление сетки к прокрутке
        self.bind('<Configure>', lambda e: self.after(100, self.redraw_grid))
    
    def draw_piano_keys(self):
        """Рисует клавиши пианино слева (классические цвета)"""
        self.delete('piano_key')
        self.delete('piano_text')
        
        key_width = 45
        
        for pitch in range(self.min_pitch, self.max_pitch + 1):
            y = (self.max_pitch - pitch) * self.pixels_per_note + 30
            is_black = pitch % 12 in [1, 3, 6, 8, 10]
            
            if is_black:
                # Чёрные клавиши
                self.create_rectangle(0, y, key_width, y + self.pixels_per_note, 
                                     fill='#1a1a1a', outline='#333333', width=1, tags='piano_key')
                self.create_text(key_width - 30, y + self.pixels_per_note // 2, 
                                text=self.get_note_name(pitch), fill='#cccccc', 
                                font=('Arial', 8, 'bold'), tags='piano_text')
            else:
                # Белые клавиши
                self.create_rectangle(0, y, key_width, y + self.pixels_per_note, 
                                     fill='#f5f5f5', outline='#999999', width=1, tags='piano_key')
                self.create_text(key_width - 30, y + self.pixels_per_note // 2, 
                                text=self.get_note_name(pitch), fill='#333333', 
                                font=('Arial', 8), tags='piano_text')
        
        # Разделительная линия
        self.create_line(key_width, 0, key_width, 2000, fill='#666666', width=2, tags='piano_key')
    
    def get_note_name(self, pitch):
        """Возвращает название ноты"""
        names = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B']
        octave = (pitch // 12) - 1
        return f"{names[pitch % 12]}{octave}"
    
    def draw_grid(self):
        """Рисует сетку на всё видимое пространство"""
        self.delete('grid')
        
        visible_width = max(2000, int(self.total_duration * self.pixels_per_second) + 200)
        visible_height = (self.max_pitch - self.min_pitch + 2) * self.pixels_per_note + 60
        
        # Вертикальные линии (время)
        for t in range(0, visible_width, 50):
            x = 45 + t
            self.create_line(x, 0, x, visible_height, fill='#404040', width=1, tags='grid')
        
        # Вертикальные линии для секунд (жирнее)
        for t in range(0, visible_width, 100):
            x = 45 + t
            self.create_line(x, 0, x, visible_height, fill='#555555', width=2, tags='grid')
        
        # Горизонтальные линии (ноты)
        for pitch in range(self.min_pitch, self.max_pitch + 1):
            y = (self.max_pitch - pitch) * self.pixels_per_note + 30
            if pitch % 12 == 0:  # C - жирная линия
                self.create_line(45, y, visible_width, y, fill='#666666', width=2, tags='grid')
            else:
                self.create_line(45, y, visible_width, y, fill='#404040', width=1, tags='grid')
        
        # Верхняя и нижняя границы
        y_top = 30
        y_bottom = (self.max_pitch - self.min_pitch + 1) * self.pixels_per_note + 30
        self.create_line(45, y_top, visible_width, y_top, fill='#666666', width=2, tags='grid')
        self.create_line(45, y_bottom, visible_width, y_bottom, fill='#666666', width=2, tags='grid')
    
    def redraw_grid(self, *args):
        """Перерисовывает сетку при изменении размера"""
        self.draw_grid()
    
    def set_midi_data(self, midi_data):
        """Загружает MIDI данные и отображает ноты"""
        self.clear_notes()
        
        max_time = 0
        
        for instrument in midi_data.instruments:
            if instrument.is_drum:
                continue
            
            for note in instrument.notes:
                if self.min_pitch <= note.pitch <= self.max_pitch:
                    self.notes.append(note)
                    max_time = max(max_time, note.end)
                    
                    # Координаты
                    x = 45 + note.start * self.pixels_per_second
                    y = (self.max_pitch - note.pitch) * self.pixels_per_note + 30
                    width = max(2, (note.end - note.start) * self.pixels_per_second)
                    height = self.pixels_per_note - 1
                    
                    # Цвет ноты зависит от высоты (градиент от синего к красному)
                    pitch_norm = (note.pitch - self.min_pitch) / (self.max_pitch - self.min_pitch)
                    r = int(41 + 214 * pitch_norm)
                    g = int(128 - 128 * pitch_norm)
                    b = int(185 - 185 * pitch_norm)
                    color = f'#{r:02x}{g:02x}{b:02x}'
                    
                    # Рисуем ноту
                    rect = self.create_rectangle(
                        x, y, x + width, y + height,
                        fill=color, outline='', width=0,
                        tags=('note', f'note_{len(self.note_rects)}')
                    )
                    
                    # Тёмная обводка
                    self.create_rectangle(
                        x, y, x + width, y + height,
                        fill='', outline='#1a1a1a', width=1,
                        tags=('note_border',)
                    )
                    
                    self.note_rects.append(rect)
        
        self.total_duration = max_time
        
        # Обновляем scrollregion
        total_width = 45 + self.total_duration * self.pixels_per_second + 200
        total_height = (self.max_pitch - self.min_pitch + 2) * self.pixels_per_note + 60
        self.config(scrollregion=(0, 0, total_width, total_height))
        
        # Перерисовываем сетку с новым размером
        self.draw_grid()
        
        # Статистика
        note_count = len(self.notes)
        if note_count > 0:
            min_p = min(n.pitch for n in self.notes)
            max_p = max(n.pitch for n in self.notes)
            self.create_text(45, 15, 
                           text=f"🎵 Нот: {note_count}  |  {self.get_note_name(min_p)} - {self.get_note_name(max_p)}  |  {self.total_duration:.1f}с",
                           fill='#333333', font=('Arial', 9, 'bold'), anchor='w', tags='stats')
    
    def clear_notes(self):
        """Очищает все ноты"""
        self.delete('note')
        self.delete('note_border')
        self.delete('stats')
        self.notes = []
        self.note_rects = []
    
    def on_mousewheel(self, event):
        """Прокрутка и масштабирование"""
        if event.state & 0x0004:  # Ctrl + колесо = масштаб
            old_scale = self.pixels_per_second
            if event.delta > 0 or event.num == 4:
                self.pixels_per_second = min(500, self.pixels_per_second * 1.2)
            else:
                self.pixels_per_second = max(20, self.pixels_per_second / 1.2)
            
            if old_scale != self.pixels_per_second:
                self.redraw_notes()
        else:  # Обычная прокрутка
            if event.delta > 0 or event.num == 4:
                self.yview_scroll(-1, 'units')
            else:
                self.yview_scroll(1, 'units')
    
    def redraw_notes(self):
        """Перерисовывает ноты после масштабирования"""
        if not self.notes:
            return
        
        self.clear_notes()
        
        for note in self.notes:
            if self.min_pitch <= note.pitch <= self.max_pitch:
                x = 45 + note.start * self.pixels_per_second
                y = (self.max_pitch - note.pitch) * self.pixels_per_note + 30
                width = max(2, (note.end - note.start) * self.pixels_per_second)
                height = self.pixels_per_note - 1
                
                pitch_norm = (note.pitch - self.min_pitch) / (self.max_pitch - self.min_pitch)
                r = int(41 + 214 * pitch_norm)
                g = int(128 - 128 * pitch_norm)
                b = int(185 - 185 * pitch_norm)
                color = f'#{r:02x}{g:02x}{b:02x}'
                
                rect = self.create_rectangle(
                    x, y, x + width, y + height,
                    fill=color, outline='', width=0,
                    tags=('note',)
                )
                self.create_rectangle(
                    x, y, x + width, y + height,
                    fill='', outline='#1a1a1a', width=1,
                    tags=('note_border',)
                )
                self.note_rects.append(rect)
        
        total_width = 45 + self.total_duration * self.pixels_per_second + 200
        total_height = (self.max_pitch - self.min_pitch + 2) * self.pixels_per_note + 60
        self.config(scrollregion=(0, 0, total_width, total_height))
        
        # Перерисовываем сетку
        self.draw_grid()


class AudioPlayer:
    """Встроенный аудиоплеер"""
    
    def __init__(self, parent, status_callback=None):
        self.parent = parent
        self.status_callback = status_callback
        self.audio_data = None
        self.sample_rate = None
        self.is_playing = False
        self.is_paused = False
        self.current_position = 0
        self.total_duration = 0
        self.update_job = None
        self.start_time = 0
        
        self.create_controls()
    
    def create_controls(self):
        self.frame = ttk.LabelFrame(self.parent, text="🎵 Плеер", padding=5)
        
        time_frame = ttk.Frame(self.frame)
        time_frame.pack(fill="x", pady=5)
        
        self.current_time_label = ttk.Label(time_frame, text="00:00")
        self.current_time_label.pack(side="left")
        
        self.progress_var = tk.DoubleVar(value=0)
        self.progress_scale = ttk.Scale(
            time_frame, from_=0, to=100, variable=self.progress_var,
            orient="horizontal", command=self.on_seek
        )
        self.progress_scale.pack(side="left", fill="x", expand=True, padx=10)
        
        self.total_time_label = ttk.Label(time_frame, text="00:00")
        self.total_time_label.pack(side="right")
        
        button_frame = ttk.Frame(self.frame)
        button_frame.pack(pady=5)
        
        self.play_button = ttk.Button(button_frame, text="▶️", width=5, command=self.play, state="disabled")
        self.play_button.pack(side="left", padx=2)
        
        self.pause_button = ttk.Button(button_frame, text="⏸️", width=5, command=self.pause, state="disabled")
        self.pause_button.pack(side="left", padx=2)
        
        self.stop_button = ttk.Button(button_frame, text="⏹️", width=5, command=self.stop, state="disabled")
        self.stop_button.pack(side="left", padx=2)
        
        self.status_label = ttk.Label(self.frame, text="Файл не загружен", foreground="gray")
        self.status_label.pack(pady=5)
    
    def load_file(self, file_path):
        try:
            self.stop()
            self.audio_data, self.sample_rate = sf.read(file_path)
            
            if len(self.audio_data.shape) > 1:
                self.audio_data = np.mean(self.audio_data, axis=1)
            
            self.total_duration = len(self.audio_data) / self.sample_rate
            self.total_time_label.config(text=self.format_time(self.total_duration))
            self.current_time_label.config(text="00:00")
            self.progress_var.set(0)
            self.current_position = 0
            
            self.play_button.config(state="normal")
            self.pause_button.config(state="disabled")
            self.stop_button.config(state="disabled")
            self.status_label.config(text=f"✅ Готово: {self.format_time(self.total_duration)}", foreground="green")
            return True
        except Exception as e:
            self.status_label.config(text=f"❌ Ошибка: {str(e)[:50]}", foreground="red")
            return False
    
    def play(self):
        if self.audio_data is None or not SOUNDDEVICE_AVAILABLE:
            return
        
        if self.is_paused:
            self.is_paused = False
            play_data = self.audio_data[self.current_position:]
            sd.play(play_data, self.sample_rate)
            self.start_time = time.time() - (self.current_position / self.sample_rate)
        else:
            seek_seconds = (self.progress_var.get() / 100) * self.total_duration
            self.current_position = int(seek_seconds * self.sample_rate)
            play_data = self.audio_data[self.current_position:]
            sd.play(play_data, self.sample_rate)
            self.start_time = time.time() - seek_seconds
        
        self.is_playing = True
        self.play_button.config(state="disabled")
        self.pause_button.config(state="normal")
        self.stop_button.config(state="normal")
        self.status_label.config(text="▶️ Воспроизведение...", foreground="#0066cc")
        
        if self.status_callback:
            self.status_callback("Воспроизведение...")
        
        self._update_timer()
    
    def pause(self):
        if self.is_playing:
            if SOUNDDEVICE_AVAILABLE:
                sd.stop()
            elapsed = time.time() - self.start_time
            self.current_position = int(elapsed * self.sample_rate)
            self.is_playing = False
            self.is_paused = True
            self.play_button.config(state="normal")
            self.pause_button.config(state="disabled")
            self.status_label.config(text="⏸️ Пауза", foreground="orange")
            if self.status_callback:
                self.status_callback("Пауза")
    
    def stop(self):
        if SOUNDDEVICE_AVAILABLE:
            sd.stop()
        self.is_playing = False
        self.is_paused = False
        self.current_position = 0
        self.progress_var.set(0)
        self.current_time_label.config(text="00:00")
        self.play_button.config(state="normal")
        self.pause_button.config(state="disabled")
        self.stop_button.config(state="disabled")
        self.status_label.config(text="⏹️ Остановлено", foreground="gray")
        if self.status_callback:
            self.status_callback("Готово")
    
    def on_seek(self, value):
        if not self.is_playing:
            pos_seconds = (float(value) / 100) * self.total_duration
            self.current_position = int(pos_seconds * self.sample_rate)
            self.current_time_label.config(text=self.format_time(pos_seconds))
    
    def _update_timer(self):
        if self.is_playing and SOUNDDEVICE_AVAILABLE:
            try:
                elapsed = time.time() - self.start_time
                if elapsed >= self.total_duration:
                    self.stop()
                else:
                    self.current_time_label.config(text=self.format_time(elapsed))
                    progress = (elapsed / self.total_duration) * 100
                    self.progress_var.set(progress)
                    self.update_job = self.parent.after(100, self._update_timer)
            except:
                self.stop()
    
    def format_time(self, seconds):
        if seconds < 0:
            seconds = 0
        minutes = int(seconds // 60)
        secs = int(seconds % 60)
        return f"{minutes:02d}:{secs:02d}"
    
    def pack(self, **kwargs):
        self.frame.pack(**kwargs)


class SimplePianoTranscriber:
    """Транскрибер мелодий с Piano Roll визуализацией"""
    
    def __init__(self, root):
        self.root = root
        self.root.title("🎹 AI Piano Transcriber")
        self.root.geometry("1000x850")
        self.root.resizable(True, True)
        
        self.input_file_path = tk.StringVar()
        self.onset_threshold = tk.DoubleVar(value=0.5)
        self.frame_threshold = tk.DoubleVar(value=0.3)
        self.min_note_length = tk.IntVar(value=58)
        self.processing = False
        self.midi_data = None
        self.result_audio_data = None
        self.result_sample_rate = None
        self.temp_dir = tempfile.mkdtemp()
        
        self.log_queue = queue.Queue()
        
        self.create_widgets()
        self.check_dependencies()
        
        sys.stderr = self
    
    def write(self, text):
        if text.strip() and "ALSA" not in text and "UserWarning" not in text and "PySoundFile" not in text:
            self.log(f"⚠️ {text.strip()}")
    
    def flush(self):
        pass
    
    def check_dependencies(self):
        self.log("🔍 Проверка зависимостей...")
        
        if not BASIC_PITCH_AVAILABLE:
            self.log(f"❌ Basic Pitch не установлен")
        else:
            self.log("✅ Basic Pitch готов")
        
        if not PRETTY_MIDI_AVAILABLE:
            self.log("❌ Pretty MIDI не установлен")
        else:
            self.log("✅ Pretty MIDI готов")
        
        if not SOUNDDEVICE_AVAILABLE:
            self.log("⚠️ SoundDevice не установлен")
        else:
            self.log("✅ SoundDevice готов")
        
        if LIBROSA_AVAILABLE:
            self.log("✅ librosa готов")
            self.mp3_converter = "librosa"
        elif PYDUB_AVAILABLE:
            self.log("⚠️ PyDub готов")
            self.mp3_converter = "pydub"
        else:
            self.log("❌ MP3 не поддерживаются")
            self.mp3_converter = None
        
        self.log("✅ Проверка завершена\n")
    
    def convert_mp3_to_wav(self, mp3_path):
        wav_path = os.path.join(self.temp_dir, "temp.wav")
        
        if self.mp3_converter == "librosa" and LIBROSA_AVAILABLE:
            self.log("   🔄 Конвертация через librosa...")
            try:
                audio, sr = librosa.load(mp3_path, sr=44100, mono=True)
                sf.write(wav_path, audio, sr)
                self.log("   ✅ Готово")
                return wav_path
            except Exception as e:
                self.log(f"   ❌ Ошибка: {e}")
                raise
        
        elif self.mp3_converter == "pydub" and PYDUB_AVAILABLE:
            self.log("   🔄 Конвертация через PyDub...")
            try:
                audio = AudioSegment.from_mp3(mp3_path)
                audio = audio.set_frame_rate(44100).set_channels(1)
                audio.export(wav_path, format="wav")
                self.log("   ✅ Готово")
                return wav_path
            except Exception as e:
                self.log(f"   ❌ Ошибка: {e}")
                raise
        
        else:
            raise ImportError("Нет конвертера MP3")
    
